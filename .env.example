# ===== GoldSave Laos — Environment Variables =====
# ไม่ใส่อะไรเลย = Demo Mode เต็มรูปแบบ (in-memory + ราคาจากแหล่งฟรี/จำลอง)

# ----- Session -----
SESSION_SECRET=          # สุ่ม string ยาวๆ สำหรับ sign session cookie (จำเป็นใน production!)

# ----- ราคาทองคำ Real-Time (เลือกอย่างใดอย่างหนึ่ง ไม่ใส่ก็ได้) -----
GOLDAPI_KEY=             # https://www.goldapi.io
METALS_DEV_KEY=          # https://metals.dev

# ----- อัตราแลกเปลี่ยน USD/LAK (ไม่ใส่ใช้ open.er-api.com ฟรี) -----
EXCHANGERATE_API_KEY=    # https://www.exchangerate-api.com

# ----- Supabase (ใส่ครบ 2 ตัว → สลับจาก Demo Mode เป็น PostgreSQL จริงอัตโนมัติ) -----
# 1. สร้างโปรเจกต์ที่ supabase.com
# 2. รัน supabase/schema.sql ใน SQL Editor
# 3. ใส่ค่าจาก Settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----- SMS Gateway สำหรับส่ง OTP จริง (ไม่ใส่ = แสดง OTP บนหน้าจอแบบ Demo) -----
# endpoint ต้องรับ POST { to, message } เช่น Twilio proxy หรือ Unitel/LTC/ETL API
SMS_GATEWAY_URL=
